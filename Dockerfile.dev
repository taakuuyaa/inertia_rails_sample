# syntax=docker/dockerfile:1
# Development image for inertia_rails-reading-notes.
# For production, see ./Dockerfile (generated by Rails).

ARG RUBY_VERSION=3.4.8
FROM docker.io/library/ruby:${RUBY_VERSION}-slim

ARG NODE_MAJOR=22
ARG PNPM_VERSION=10

ENV LANG=C.UTF-8 \
    BUNDLE_PATH=/usr/local/bundle \
    PNPM_HOME=/root/.local/share/pnpm \
    PATH=/root/.local/share/pnpm:$PATH

RUN apt-get update -qq \
 && apt-get install --no-install-recommends -y \
      build-essential \
      ca-certificates \
      curl \
      git \
      gnupg \
      libsqlite3-dev \
      libyaml-dev \
      pkg-config \
      sqlite3 \
 && curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - \
 && apt-get install --no-install-recommends -y nodejs \
 && npm install -g "pnpm@${PNPM_VERSION}" \
 && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

RUN gem install foreman bundler --no-document

WORKDIR /app

# Pre-install gems and node_modules into the image so first run is fast.
# These layers are invalidated only when Gemfile/lock or package.json/lock change.
COPY Gemfile Gemfile.lock ./
RUN bundle install

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

EXPOSE 3000 3036

CMD ["bin/dev"]
